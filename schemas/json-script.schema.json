{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://open-video-automation-framework.local/schemas/json-script.schema.json",
  "title": "Open Video Automation JSON Script",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "project", "settings", "scenes"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "language"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "enum": ["vi", "en"]
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aspectRatio",
        "width",
        "height",
        "fps",
        "maxDurationSeconds",
        "voiceEnabled",
        "musicEnabled",
        "subtitleEnabled"
      ],
      "properties": {
        "aspectRatio": {
          "type": "string",
          "const": "9:16"
        },
        "width": {
          "type": "integer",
          "const": 1080
        },
        "height": {
          "type": "integer",
          "const": 1920
        },
        "fps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120
        },
        "maxDurationSeconds": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 60
        },
        "voiceEnabled": {
          "type": "boolean"
        },
        "musicEnabled": {
          "type": "boolean"
        },
        "subtitleEnabled": {
          "type": "boolean"
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scene"
      }
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "durationSeconds", "layers"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "durationSeconds": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 60
        },
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/layer"
          }
        },
        "transition": {
          "$ref": "#/$defs/sceneTransition"
        },
        "voice": {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["background", "text", "image", "video"]
        },
        "content": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "animation": {
          "oneOf": [
            {
              "$ref": "#/$defs/animationTiming"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/animationTiming"
              }
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "text"
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "content": true
            },
            "required": ["content"]
          }
        }
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["color", "asset"]
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "color"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "value": true
            },
            "required": ["value"]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "asset"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "path": true
            },
            "required": ["path"]
          }
        }
      ]
    },
    "animationTiming": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "startMs", "durationMs"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["fade", "slide-up", "slide-left", "zoom-in", "zoom-out"]
        },
        "startMs": {
          "type": "number",
          "minimum": 0
        },
        "durationMs": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "easing": {
          "type": "string",
          "enum": ["linear", "ease-in", "ease-out", "ease-in-out"]
        }
      }
    },
    "sceneTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "durationMs"],
      "properties": {
        "name": {
          "type": "string",
          "const": "fade"
        },
        "durationMs": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
