{
  "name": "open-video-automation-framework",
  "version": "0.0.0",
  "private": true,
  "description": "Specification-first, AI-agnostic framework for deterministic vertical video automation.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "npm run check:workspace && npm run typecheck && npm test",
    "check:workspace": "node scripts/check-workspace.mjs",
    "db:migrate": "node packages/persistence/dist/cli/migrate.js",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
